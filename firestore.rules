// firestore.rules
// 
// Firebase Firestore Security Rules
//
// DEPLOY:
//   Firebase Console → Firestore Database → Rules → paste → Publish
//   OR: firebase deploy --only firestore:rules
//
// WHAT CHANGED FROM YOUR PREVIOUS RULES:
// 
// The previous rules used complex isValidUserCreate() with hasOnly()
// which was overly strict. More importantly, the old rules assumed
// the document ID was the Auth UID — but db.js was using addDoc()
// which generates a RANDOM document ID, so every rule check of
// request.auth.uid == uid (the doc ID) always failed.
//
// These rules match the new UID-as-document-ID model in db.js:
//   users/{uid}  where uid = Firebase Auth UID = document ID
//
// The usersByUid collection is removed — it's no longer needed
// because isAdmin() can now do a direct getDoc(users/{request.auth.uid})
// instead of a query.
//
// COLLECTION STRUCTURE:
//   categories/{slug}                  — roadmap metadata
//   categories/{slug}/topics/{id}      — topic documents
//   users/{uid}                        — user profiles (uid = Auth UID)
//   progress/{uid}/checkboxes/{slug}   — per-user progress
//
// PERMISSION MATRIX:
// ┬─┬┬─
//                                           │ Guest │ User │ Admin
// ┼─┼┼─
// Read categories / topics                 │  ✅   │  ✅  │  ✅
// Create/edit/delete categories / topics   │  ❌   │  ❌  │  ✅
// Read own user profile                    │  ❌   │  ✅  │  ✅
// Read all user profiles (admin panel)     │  ❌   │  ❌  │  ✅
// Create own user profile (signup)         │  ❌   │  ✅  │  ✅
// Update own non-role fields               │  ❌   │  ✅  │  ✅
// Update role (promote/demote)             │  ❌   │  ❌  │  ✅
// Delete user profiles                     │  ❌   │  ❌  │  ✅
// Read/write own progress                  │  ❌   │  ✅  │  ✅
// Read another user's progress             │  ❌   │  ❌  │  ❌
// 

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    

    function isSignedIn() {
      return request.auth != null;
    }

    
    
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    /**
     * Server-side admin check.
     * Reads users/{request.auth.uid}.role directly — O(1) getDoc.
     * Cannot be spoofed by client-side JS.
     * No query needed because document ID = Auth UID.
     */
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    
    function isValidRole(role) {
      return role == 'admin' || role == 'user';
    }

    
    function isChangingRole() {
      return 'role' in request.resource.data.diff(resource.data).affectedKeys();
    }

    

    match /categories/{slug} {
      
      allow read: if isSignedIn();

      
      allow create, update, delete: if isAdmin();

      match /topics/{topicId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isAdmin();
      }
    }

    
    
    

    match /users/{uid} {

      
      
      allow read: if isOwner(uid) || isAdmin();

      
      
      
      
      allow create: if isOwner(uid)
        && request.resource.data.role == 'user'
        && isValidRole(request.resource.data.role)
        && request.resource.data.email == request.auth.token.email;

      
      
      allow update: if
        (isOwner(uid) && !isChangingRole())
        || isAdmin();

      
      allow delete: if isAdmin();
    }

    
    
    

    match /progress/{uid} {
      allow read, write: if isOwner(uid);

      match /checkboxes/{categorySlug} {
        allow read, write: if isOwner(uid);
      }
    }

    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
